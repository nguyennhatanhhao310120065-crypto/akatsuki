<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.judgeTool.controller.CheckerController" spacing="10">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Đề"/>
        <ComboBox fx:id="problemCombo" prefWidth="300"/>
        <ToggleButton fx:id="toggleExact" text="Exact match" selected="true"/>
        <ToggleButton fx:id="toggleSpecial" text="Special judge"/>
    </HBox>
    <Label text="Mã checker (Python, 3 tham số: input, expected, contestant)"/>
    <TextArea fx:id="checkerCode" prefRowCount="14" wrapText="true"/>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button text="Sinh checker bằng AI" onAction="#genAi"/>
        <Button text="Lưu checker" onAction="#saveChecker"/>
        <Button text="Test checker (testcase đầu)" onAction="#testChecker"/>
        <ProgressIndicator fx:id="aiProgress" visible="false" prefWidth="28" prefHeight="28"/>
    </HBox>
</VBox>
